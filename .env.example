# Copy to .env and fill secrets. Values match src/config/env.ts.
#
# Docker: erp-execution-service must join external network axiserp-erpnext-pnzjyk_axis-erp-internal
# (see docker-compose.yml) so this hostname resolves from the container.
#
# Do NOT set obsolete bench/DB vars (ERP_BENCH_PATH, ERP_BENCH_EXECUTABLE, ERP_ADMIN_PASSWORD,
# ERP_DB_ROOT_PASSWORD, ERP_DB_HOST, ERP_DB_PORT, ERP_SKIP_BENCH_RUNTIME_CHECK, ERP_VALIDATE_DB_SCHEMA).

NODE_ENV=development
PORT=8790

# Inbound: Bearer token for POST /v1/erp/lifecycle (same as provisioning-agent ERP_REMOTE_TOKEN)
ERP_REMOTE_TOKEN=change-me-min-16-chars-long

# Outbound: ERP Frappe origin (no trailing slash). Intended runtime on shared ERP network:
ERP_BASE_URL=http://axis-erp-backend:8000

# Outbound: Bearer token for provisioning_api whitelisted methods.
# Must match provisioning_api_token in ERP sites/common_site_config.json
ERP_PROVISIONING_TOKEN=change-me-min-16-chars-long

ERP_COMMAND_TIMEOUT_MS=30000

# Optional overrides (defaults target provisioning_api.api.provisioning.*)
# ERP_METHOD_CREATE_SITE=provisioning_api.api.provisioning.create_site
# ERP_METHOD_READ_SITE_DB_NAME=provisioning_api.api.provisioning.read_site_db_name
# ERP_METHOD_INSTALL_ERP=provisioning_api.api.provisioning.install_erp
# ERP_METHOD_ENABLE_SCHEDULER=provisioning_api.api.provisioning.enable_scheduler
# ERP_METHOD_ADD_DOMAIN=provisioning_api.api.provisioning.add_domain
# ERP_METHOD_CREATE_API_USER=provisioning_api.api.provisioning.create_api_user
