# Schema for `src/config/env.ts`. Copy to `.env` for local Docker Compose / dev (see README).
# Production values are configured in Dokploy (or your host environment), not from a committed `.env`.
#
# Docker (local): ensure external network `axiserp-erpnext-pnzjyk_axis-erp-internal` exists (see `docker-compose.yml`)
# so `axis-erp-backend` resolves from the container.
#
# Do not set obsolete bench/DB vars (ERP_BENCH_PATH, ERP_BENCH_EXECUTABLE, ERP_ADMIN_PASSWORD,
# ERP_DB_ROOT_PASSWORD, ERP_DB_HOST, ERP_DB_PORT, ERP_SKIP_BENCH_RUNTIME_CHECK, ERP_VALIDATE_DB_SCHEMA).

# Node environment: development | test | production
NODE_ENV=production

# HTTP listen port (host and container mapping in compose)
PORT=8790

# Inbound: Bearer token for POST /sites/create (minimum 16 characters; must match provisioning-agent remote token)
ERP_REMOTE_TOKEN=local-insecure-bearer-token-32chars

# Milliseconds timeout for each docker exec (bench new-site and set-config each use this budget)
ERP_COMMAND_TIMEOUT_MS=30000

# Docker CLI path and backend container for `docker exec … bench …` (host socket mounted in compose)
ERP_DOCKER_BIN=docker
ERP_DOCKER_BACKEND_CONTAINER=axiserp-erpnext-pnzjyk-backend-1
ERP_NEW_SITE_ADMIN_PASSWORD=9Obtpzkb8c8

# Outbound: ERP Frappe origin (no trailing slash). Example on shared ERP network (optional; health ping):
ERP_BASE_URL=http://axis-erp-backend:8000

# Outbound: HTTP Host header for Frappe multi-site (required when ERP_BASE_URL is set). Used for ping/health when
# the RPC has no site; create_site body uses site_name as Host for that request.
ERP_SITE_HOST=erp.zaidan-group.com

# Outbound: provisioning_api shared secret (minimum 16 characters when set). Sent as X-Provisioning-Token;
# must match provisioning_api_token in ERP sites/common_site_config.json
ERP_PROVISIONING_TOKEN=local-insecure-provision-token-32

# Frappe dotted method for create_site (POST /api/method/{path}); override only if your ERP uses a different route
ERP_METHOD_CREATE_SITE=provisioning_api.api.provisioning.create_site
