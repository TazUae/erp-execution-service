# Template committed for predictable variable names after `git pull`. Replace values per environment;
# use `.env.local` / `.env.production` / `.env.secrets` for overrides (gitignored).

# Node environment: development | test | production
NODE_ENV=production

# HTTP listen port (host and container mapping in compose)
PORT=8790

# Inbound: Bearer token for POST /v1/erp/lifecycle (minimum 16 characters; must match provisioning-agent remote token)
ERP_REMOTE_TOKEN=local-insecure-bearer-token-32chars

# Milliseconds timeout for outbound Frappe HTTP requests
ERP_COMMAND_TIMEOUT_MS=30000

# Outbound: ERP Frappe origin (no trailing slash). Example on shared ERP network:
ERP_BASE_URL=http://axis-erp-backend:8000

# Outbound: provisioning_api shared secret (minimum 16 characters when set). Sent as X-Provisioning-Token;
# must match provisioning_api_token in ERP sites/common_site_config.json
ERP_PROVISIONING_TOKEN=local-insecure-provision-token-32

# Frappe dotted method paths (POST /api/method/{path}); override only if your ERP uses different routes
ERP_METHOD_CREATE_SITE=provisioning_api.api.provisioning.create_site
ERP_METHOD_READ_SITE_DB_NAME=provisioning_api.api.provisioning.read_site_db_name
ERP_METHOD_INSTALL_ERP=provisioning_api.api.provisioning.install_erp
ERP_METHOD_ENABLE_SCHEDULER=provisioning_api.api.provisioning.enable_scheduler
ERP_METHOD_ADD_DOMAIN=provisioning_api.api.provisioning.add_domain
ERP_METHOD_CREATE_API_USER=provisioning_api.api.provisioning.create_api_user
